# Supabase ローカル開発用 Publishable Key
# supabase start 実行後に表示される "anon key" を入力する
# 例: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_PUBLISHABLE_KEY=

# Supabase サーバーサイド接続用の内部URL（Docker Compose 環境でのみ使用）
# Docker コンテナ内の Next.js サーバーはこの URL で Supabase に接続する
# ブラウザ（クライアント）は NEXT_PUBLIC_SUPABASE_URL（localhost）を使うため
# host.docker.internal への DNS エラーを回避できる
# DevContainer / Vercel 環境では設定不要（未設定時は NEXT_PUBLIC_SUPABASE_URL を使用）
# docker-compose.yml でデフォルト値（http://host.docker.internal:54321）を設定済み。
# 別の URL を使いたい場合のみここで上書きする。
SUPABASE_INTERNAL_URL=

# ESP32エミュレータ用 デバイスAPIキー
# supabase/seed.sql に登録済みの開発用キー（dev-api-key-001）をそのまま使用可能
DEVICE_API_KEY=dev-api-key-001

# Next.js アプリの公開URL（OAuth コールバック用）
# ローカル開発: http://localhost:3000
# Vercel デプロイ時: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub OAuth（Supabase Auth Provider 設定用）
# GitHub OAuth App の Client ID / Client Secret を設定する
# Authorization callback URL は http://127.0.0.1:54321/auth/v1/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ログイン許可リスト
# ALLOWED_EMAILS・ALLOWED_GITHUB_USERNAMES がどちらも未設定の場合は全員拒否される（無意識の全公開を防ぐ）
# メールアドレスまたは GitHub ユーザー名のいずれかに一致すれば許可（OR 条件）
# どちらか一方のみの設定でも動作する
# カンマ区切りで複数のメールアドレスを指定可能
# 例: alice@example.com,bob@example.com
ALLOWED_EMAILS=
# カンマ区切りで複数のGitHubユーザー名を指定可能
# 例: alice-github,bob-github
ALLOWED_GITHUB_USERNAMES=
