# ESP32エミュレータ 環境変数設定ファイル
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env

# エミュレータが待ち受けるポート番号
# デフォルト: 3001
PORT=3001

# Supabase のローカル開発用 URL
# DevContainer / Docker Compose 経由で起動する場合: http://host.docker.internal:54321
# ホストから直接 ts-node で起動する場合: http://localhost:54321
SUPABASE_URL=http://host.docker.internal:54321

# デバイス用 API キー
# supabase/seed.sql に登録済みの開発用キー (dev-api-key-001) をそのまま使用できます
# USER_JWT_TOKEN が設定されている場合、こちらは使用されません
DEVICE_API_KEY=dev-api-key-001

# (オプション) ログインユーザーの JWT トークン
# 設定すると、DEVICE_API_KEY の代わりにこのトークンを Authorization: Bearer に使用します
# GitHub OAuth などでログインしたユーザーとして送信したい場合に設定してください
#
# 取得方法:
#   A. Supabase Studio (http://localhost:54323) → Authentication > Users
#      → 対象ユーザーの行にある "..." メニュー → "Copy JWT" を選択
#
#   B. ブラウザの DevTools → Application タブ → Cookies
#      → sb-*-auth-token クッキーの値から access_token を取得
#      （JSON をパースして access_token フィールドの値をコピー）
#
# 設定例:
#   USER_JWT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
USER_JWT_TOKEN=
